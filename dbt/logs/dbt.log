    as (-- =========================================================
-- Model: dim_consultant
-- Layer: Mart (Dimension)
-- Purpose: Sales consultant performance tracking
-- =========================================================

select

    SALES_CONSULTANT,

    count(*) as TOTAL_CONTRACTS,

    sum(CONTRACT_PRICE) as TOTAL_SALES,

    avg(CONTRACT_PRICE) as AVG_CONTRACT_PRICE,

    avg(DAYS_TO_CLOSE) as AVG_DAYS_TO_CLOSE

from db_Real_Estate.staging.stg_homebuilder_sales

group by SALES_CONSULTANT
    )

/* {"app": "dbt", "dbt_version": "1.11.8", "profile_name": "rhodes_analytics", "target_name": "dev", "node_id": "model.rhodes_analytics.dim_consultant"} */;
[0m00:18:17.870403 [debug] [Thread-11 ]: Using snowflake connection "model.rhodes_analytics.sales_forecast"
[0m00:18:17.871402 [debug] [Thread-7 (]: On model.rhodes_analytics.dim_region: create or replace transient table db_Real_Estate.staging_marts.dim_region
    
    
    
    as (-- =========================================================
-- Model: dim_region
-- Layer: Mart (Dimension)
-- Purpose: Enables slicing, targeting, and performance comparison
-- =========================================================

with sales as (
    select *
    from db_Real_Estate.staging.stg_homebuilder_sales
),

region_lookup as (
    select *
    from db_Real_Estate.staging.stg_regional_lookup
)

select

    -- =========================
    -- DIMENSION KEY
    -- =========================
    s.REGION,

    -- =========================
    -- CONTEXT (slice/dice fields)
    -- =========================
    r.REGIONAL_MANAGER,

    -- =========================
    -- ACTUAL PERFORMANCE
    -- =========================
    count(s.CONTRACT_ID) as TOTAL_CONTRACTS,
    sum(s.CONTRACT_PRICE) as TOTAL_SALES,
    avg(s.CONTRACT_PRICE) as AVG_SALES_PRICE,
    avg(s.DAYS_TO_CLOSE) as AVG_DAYS_TO_CLOSE,

    -- =========================
    -- TARGETS (FROM LOOKUP)
    -- =========================
    max(r.SALES_TARGET_UNITS) as SALES_TARGET_UNITS,
    max(r.MARGIN_TARGET_PCT) as MARGIN_TARGET_PCT,

    -- =========================
    -- PERFORMANCE GAP (VERY IMPORTANT)
    -- =========================
    count(s.CONTRACT_ID) - max(r.SALES_TARGET_UNITS) as CONTRACT_GAP

from sales s

left join region_lookup r
    on s.REGION = r.REGION

group by
    s.REGION,
    r.REGIONAL_MANAGER
    )

/* {"app": "dbt", "dbt_version": "1.11.8", "profile_name": "rhodes_analytics", "target_name": "dev", "node_id": "model.rhodes_analytics.dim_region"} */;
