    sum(CONTRACT_PRICE) as TOTAL_SALES,

    avg(CONTRACT_PRICE) as AVG_CONTRACT_PRICE,

    avg(DAYS_TO_CLOSE) as AVG_DAYS_TO_CLOSE

from db_Real_Estate.staging_staging.stg_homebuilder_sales

